# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# --- Single account (backward-compatible) ---
# Option 1: File-based session (a .session file will be created on disk)
TELEGRAM_SESSION_NAME=telegram_session
# Option 2: String-based session (no file on disk; recommended)
# TELEGRAM_SESSION_STRING=1231231232erfdfdffd

# --- macOS Keychain (more secure alternative to storing values above) ---
# Store credentials in the system keychain so they never appear in plaintext files.
# Run once to store each value:
#   security add-generic-password -a "$USER" -s telegram-api-id      -w "YOUR_API_ID"
#   security add-generic-password -a "$USER" -s telegram-api-hash     -w "YOUR_API_HASH"
#   security add-generic-password -a "$USER" -s telegram-session-string -w "YOUR_SESSION_STRING"
#
# Then export the vars before starting the server (e.g. in ~/.zshrc or a wrapper script):
#   export TELEGRAM_API_ID=$(security find-generic-password -a "$USER" -s telegram-api-id -w)
#   export TELEGRAM_API_HASH=$(security find-generic-password -a "$USER" -s telegram-api-hash -w)
#   export TELEGRAM_SESSION_STRING=$(security find-generic-password -a "$USER" -s telegram-session-string -w)
#
# When env vars are set this way, leave the fields in this file commented out.

# --- Multiple accounts ---
# Add _<LABEL> suffix to session variables. Labels become account identifiers.
# Shared API_ID and API_HASH are used for all accounts.
# TELEGRAM_SESSION_STRING_WORK=<session string for work account>
# TELEGRAM_SESSION_STRING_PERSONAL=<session string for personal account>

# --- Tool access control (optional) ---
# The following high-risk tools are DISABLED by default (not visible to the MCP client):
#   delete_message, delete_chat_history, delete_messages_bulk,
#   delete_scheduled_message, delete_folder, delete_contact,
#   delete_profile_photo, delete_chat_photo, ban_user,
#   promote_admin, demote_admin, create_group, create_channel,
#   export_contacts, export_chat_invite
#
# Set TELEGRAM_ENABLE_DANGEROUS_TOOLS=1 to allow them:
# TELEGRAM_ENABLE_DANGEROUS_TOOLS=0
#
# To additionally disable specific tools by name (comma-separated), use:
# TELEGRAM_DISABLE_TOOLS=delete_message,delete_chat_history,delete_messages_bulk,delete_scheduled_message,delete_folder,delete_contact,delete_profile_photo,delete_chat_photo,ban_user,promote_admin,demote_admin,create_group,create_channel,export_contacts,export_chat_invite

# --- Proxy (optional) ---
# Route Telegram traffic through a proxy. Set TELEGRAM_PROXY_TYPE to enable.
# Supported types: socks5, socks4, http, mtproxy.
# SOCKS/HTTP proxies require the 'python-socks' package (install via
# `uv sync --extra proxy` or `pip install python-socks`).
# Per-account overrides use the same _<LABEL> suffix as session variables.
# TELEGRAM_PROXY_TYPE=socks5
# TELEGRAM_PROXY_HOST=127.0.0.1
# TELEGRAM_PROXY_PORT=1080
# TELEGRAM_PROXY_USERNAME=<optional>
# TELEGRAM_PROXY_PASSWORD=<optional>
# TELEGRAM_PROXY_RDNS=true
# For MTProxy, set TELEGRAM_PROXY_TYPE=mtproxy and provide the secret:
# TELEGRAM_PROXY_SECRET=<hex secret>
# Per-account override example:
# TELEGRAM_PROXY_TYPE_WORK=http
# TELEGRAM_PROXY_HOST_WORK=proxy.work.example
# TELEGRAM_PROXY_PORT_WORK=3128
